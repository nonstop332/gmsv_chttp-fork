+#ifdef CURLPROXY_SOCKS5_HOSTNAME
+    if (value == "socks5h") return CURLPROXY_SOCKS5_HOSTNAME;
+#endif
+    return -1;
+}
+
+static long parse_proxy_auth_value(std::string const& value)
+{
