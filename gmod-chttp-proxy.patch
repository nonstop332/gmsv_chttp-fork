+static bool table_get_string(GarrysMod::Lua::ILuaBase* LUA, int index, char const* key, std::string& out)
+{
+    LUA->GetField(index, key);
+    if (!LUA->IsType(-1, GarrysMod::Lua::Type::String)) {
+        LUA->Pop();
+        return false;
+    }
+    out = LUA->GetString(-1);
+    LUA->Pop();
+    return true;
+}
+
+static long parse_proxy_type_value(std::string const& value)
+{
+    if (value == "http") return CURLPROXY_HTTP;
+#ifdef CURLPROXY_HTTPS
